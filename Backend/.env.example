# Twilio Account SID
TWILIOSID=paste_your_account_sid_here

# Twilio Auth Token
TWILIOTOK=paste_your_auth_token_here

# Twilio Phone Number (must include whatsapp: prefix, e.g., whatsapp:+14155238886)
TWILIONUM=whatsapp:+14155238886

# Admin Phone Number (must include whatsapp: prefix, e.g., whatsapp:+917389650928)
ADMINPHONE=whatsapp:+917389650928

# Server Port
PORT=3000
